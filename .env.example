# Required: get this from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTH_TOKEN=your_ngrok_auth_token_here

# Optional: use a reserved ngrok domain if your plan supports it
# NGROK_DOMAIN=your-subdomain.ngrok.app

# Optional: ngrok region (us, eu, ap, au, sa, jp, in)
# NGROK_REGION=us

# Optional: ngrok auto-reconnect watchdog tuning
# NGROK_RECONNECT_CHECK_SECONDS=15
# NGROK_RECONNECT_FAILURE_THRESHOLD=2
# NGROK_RECONNECT_MAX_ATTEMPTS=0
# NGROK_RECONNECT_INITIAL_BACKOFF_SECONDS=1.0

# Optional: local LLM server URL (used by `make run` unified mode)
# LLM_LOCAL_URL=http://localhost:8317

# Optional: local endpoint for direct tunnel mode (`make run-llm-direct`)
# LOCAL_URL=http://localhost:8317

# Optional: local LLM retry-proxy port (`make run-llm`)
# LLM_PROXY_PORT=8330

# Optional: local Codex bridge port (`make run-codex`)
# CODEX_BRIDGE_PORT=8340

# Optional: local multi-CLI bridge port (`make run-gemini`, `make run-cli`)
# CLI_BRIDGE_PORT=8350

# Optional: multi-CLI bridge startup timeout in seconds
# CLI_BRIDGE_STARTUP_TIMEOUT=120

# Optional: bearer token required by the Gemini/combined CLI bridge.
# Falls back to CODEX_BRIDGE_AUTH_TOKEN if unset.
# CLI_BRIDGE_AUTH_TOKEN=change_me

# Optional: default providers for `run_cli_pipeline.py`
# CLI_BRIDGE_PROVIDERS=codex,gemini
# CLI_BRIDGE_DEFAULT_PROVIDER=codex

# Optional: Codex bridge startup timeout in seconds
# CODEX_BRIDGE_STARTUP_TIMEOUT=120

# Optional: bearer token required by the Codex bridge.
# Strongly recommended before exposing the bridge over ngrok.
# CODEX_BRIDGE_AUTH_TOKEN=change_me

# Optional: Codex CLI binary path/name
# CODEX_BINARY=codex

# Optional: working directory passed to `codex exec -C`
# CODEX_WORKDIR=/absolute/path/to/workdir

# Optional: sandbox passed to `codex exec --sandbox`
# CODEX_SANDBOX=read-only

# Optional: Codex profile/model overrides
# CODEX_PROFILE=
# CODEX_MODEL=

# Optional: additional writable directories for Codex, comma-separated
# CODEX_ADD_DIRS=/absolute/path/one,/absolute/path/two

# Optional: Codex exec runtime behavior
# CODEX_EPHEMERAL=true
# CODEX_SKIP_GIT_REPO_CHECK=false
# CODEX_ENABLE_WEB_SEARCH=false
# CODEX_MAX_CONCURRENCY=1
# CODEX_REQUEST_TIMEOUT_SECONDS=900

# Optional: Gemini CLI binary path/name
# GEMINI_BINARY=gemini

# Optional: Gemini working directory
# GEMINI_WORKDIR=/absolute/path/to/workdir

# Optional: Gemini model override
# GEMINI_MODEL=

# Optional: Gemini sandbox + approvals
# GEMINI_SANDBOX=true
# GEMINI_APPROVAL_MODE=default

# Optional: Gemini extra workspace directories and extensions, comma-separated
# GEMINI_INCLUDE_DIRECTORIES=/absolute/path/one,/absolute/path/two
# GEMINI_EXTENSIONS=

# Optional: Gemini runtime behavior
# GEMINI_MAX_CONCURRENCY=1
# GEMINI_REQUEST_TIMEOUT_SECONDS=900

# Optional: STT server port for unified mode
# STT_PORT=8320

# Optional: STT backend (default on Apple Silicon: mlx)
# STT_BACKEND=mlx

# Optional: Whisper model id.
# For MLX backend, recommended:
# WHISPER_MODEL=mlx-community/whisper-large-v3-turbo
# For faster-whisper backend:
# WHISPER_MODEL=large-v3

# Optional: faster-whisper runtime settings
# WHISPER_DEVICE=auto
# WHISPER_COMPUTE_TYPE=int8

# Optional: MLX runtime settings
# MLX_FP16=true

# Optional: preload model on server startup (set false for lazy load)
# STT_EAGER_LOAD=true

# Optional: unload model after idle seconds (0 disables auto-unload)
# STT_IDLE_UNLOAD_SECONDS=900

# Optional: monitor interval for idle unload checks (seconds)
# STT_IDLE_CHECK_SECONDS=15

# Optional: retries for LLM proxy requests
# PROXY_RETRY_ATTEMPTS=2
# PROXY_RETRY_BACKOFF_SECONDS=0.35
# PROXY_RETRY_MAX_BACKOFF_SECONDS=2.0
# PROXY_RETRY_METHODS=GET,HEAD,POST

# Optional: retry 429 responses (disabled by default).
# When enabled, proxy also respects Retry-After (seconds or HTTP date) if provided,
# capped by PROXY_RETRY_429_MAX_DELAY_SECONDS.
# PROXY_RETRY_ON_429=false
# PROXY_RETRY_429_MAX_DELAY_SECONDS=30

# Optional: for non-streaming requests, buffer full upstream response before sending
# (reduces stream-interrupted errors for /v1/responses stream=false)
# PROXY_BUFFER_NON_STREAMING=true

# Optional: additional retries if non-streaming body read fails after headers
# PROXY_NONSTREAM_READ_RETRY_ATTEMPTS=1

# Optional: Hugging Face token (needed for private/gated models)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
